# ─── Database ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=forensics_db
POSTGRES_USER=forensics_user
POSTGRES_PASSWORD=change_me_in_production

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=forensics
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_VHOST=/

# ─── MinIO / S3 Object Storage ──────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET=forensics-bucket
MINIO_USE_SSL=false

# ─── Authentication ───────────────────────────────────────────
JWT_SECRET_KEY=change_me_to_a_secure_random_string_in_production
# Optional overrrides
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
