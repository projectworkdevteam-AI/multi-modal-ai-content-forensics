# ─── Database ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=forensics_db
POSTGRES_USER=forensics_user
POSTGRES_PASSWORD=your_secure_postgres_password_here

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_USER=forensics
RABBITMQ_PASSWORD=your_secure_rabbitmq_password_here
RABBITMQ_URL=amqp://forensics:your_secure_rabbitmq_password_here@localhost:5672/

# ─── MinIO / S3 Object Storage ──────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_secure_minio_password_here
MINIO_SECURE=false

# ─── Authentication ───────────────────────────────────────────
JWT_SECRET_KEY=change_me_to_a_secure_random_string_in_production
AUTH_SERVICE_URL=http://auth-service:8001/api/v1/authg_key_here
